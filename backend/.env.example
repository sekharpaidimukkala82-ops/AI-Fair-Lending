# Copy this file to .env and fill in your values

# ── AI Providers (set at least one) ───────────────────────────────────────────

# Google Gemini  — https://aistudio.google.com/app/apikey  (enable billing for quota)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (GPT)   — https://platform.openai.com/api-keys  (requires $5 minimum credit)
OPENAI_API_KEY=your_openai_api_key_here

# Groq ⚡ FREE   — https://console.groq.com/keys  (no billing required — LLaMA / Mixtral)
GROQ_API_KEY=your_groq_api_key_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this in production! Use a long random string.
SECRET_KEY=change-this-in-production-use-32-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Storage paths (defaults shown) ───────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
UPLOAD_DIR=./uploads
MODELS_DIR=./models_store

# ── Database (leave blank for SQLite dev mode) ────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fairlend

# Priority 4 — Observability (optional)
SENTRY_DSN=
ENVIRONMENT=development
APP_VERSION=2.0.0
LOG_FORMAT=text
